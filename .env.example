# Never commit real keys. Copy this file to .env locally or set env vars in your host.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_FORECASTER_MODEL=gpt-5.5
OPENAI_VERIFIER_MODEL=gpt-5.5
OPENAI_SYNTHESIZER_MODEL=gpt-5.5
FORECAST_BRANCH_COUNT=2

EXA_API_KEY=
EXA_SEARCH_ROUNDS=2
EXA_RESULTS_PER_QUERY=4
EXA_MAX_SOURCES=10
EXA_RESEARCH_MODE=llm
EXA_USE_LLM_PLANNER=true
EXA_RESEARCH_MODEL=gpt-5.4-mini
EXA_RESEARCH_REASONING_EFFORT=low
EXA_RESEARCH_QUERIES_PER_ROUND=4
EXA_RESEARCH_TIMEOUT_SECONDS=25
EXA_RESEARCH_MAX_SECONDS=420
EXA_SEARCH_TIMEOUT_SECONDS=20

# Optional inbound endpoint protection. Leave blank if Prophet Arena calls the endpoint without auth.
AGENT_API_KEY=

# Used only by the Prophet CLI when registering/submitting, not by the web server itself.
PA_SERVER_API_KEY=
PA_TEAM_NAME=
